# Copy to .env for local development. Never commit the filled-in file.

# CockroachDB / Postgres connection string.
# CockroachDB Cloud: use the POOLED connection string, port 26257, sslmode=require.
DATABASE_URL="postgresql://user:password@host:26257/trackly?sslmode=require"

# Session signing key. Generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public URL of the deployment. Required in production so OAuth callbacks resolve.
AUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST=true

# Google OAuth (optional). Leave blank to hide the "Continue with Google" button.
# Authorised redirect URI must be exactly <AUTH_URL>/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Vercel Blob storage for ticket attachments.
# Create a Blob store in the Vercel dashboard; the token is generated for you.
# Without this, uploads are refused with a clear message rather than failing silently.
BLOB_READ_WRITE_TOKEN=""
